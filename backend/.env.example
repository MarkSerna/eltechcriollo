# Configuración de Entorno
# ========================

# Seguridad y acceso
SECRET_KEY=
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
SESSION_COOKIE_NAME=techcriollo_session
SESSION_MAX_AGE=43200
SESSION_SECURE=false
SESSION_SAME_SITE=lax
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8088,http://127.0.0.1:8088

# Base de datos local y fuentes
DB_DIR=data
DB_NAME=history.db
SOURCES_PATH=data/sources.json

# Webhook (Discord / Telegram)
# Si lo dejas vacío, no se enviarán# Notificaciones (Discord / Telegram)
DISCORD_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Configuración de Archivos
REPORTS_DIR=reports
LOGS_DIR=logs
LOG_LEVEL=INFO

# Retención (Archivos más viejos a estos días se auto-borran o no se envían)
CLEANUP_DAYS=7

# Configuración Inteligencia Artificial
# AI_PROVIDER: 'local' (Ollama) o 'gemini' (Google Cloud)
AI_PROVIDER=gemini
GEMINI_COOLDOWN=60

# Ollama (Local / Docker)
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=gemma4:31b-cloud

# Google Gemini
GEMINI_API_KEY=
