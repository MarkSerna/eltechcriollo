# Configuración de Entorno - El Tech Criollo
# ==========================================

# 1. Base de datos
# ----------------
# Local (por defecto si no hay DATABASE_URL)
DB_DIR=data
DB_NAME=tech_history.db
# Nube (Supabase / PostgreSQL) - RECOMENDADO PARA DESPLIEGUE CLOUD
# DATABASE_URL=postgresql://user:password@host:port/dbname

# 2. Notificaciones y Bot
# -----------------------
TELEGRAM_BOT_TOKEN=tu_token_aqui
TELEGRAM_CHAT_ID=tu_chat_id_aqui
DISCORD_WEBHOOK_URL=

# 3. Inteligencia Artificial (IA)
# -------------------------------
# OPCIÓN A: Google Gemini (Recomendado para Cloud Gratuito)
GEMINI_API_KEY=tu_api_key_aqui

# OPCIÓN B: Ollama (Local / Docker)
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=gemma4:31b-cloud

# 4. Configuración interna
# ------------------------
SOURCES_PATH=data/sources.json
REPORTS_DIR=reports
LOGS_DIR=logs
LOG_LEVEL=INFO
CLEANUP_DAYS=7
